<h1 class="mb-4"><%= t ".title" %></h1>

<div class="row mb-4">
  <div class="col-md-6">
    <%= form_with url: search_products_path, method: :get, class: "d-flex" do %>
      <%= text_field_tag :q, nil, class: "form-control me-2", placeholder: "Search products..." %>
      <%= submit_tag "Search", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
  <%# <h1>Products</h1> %>
  <% if user_signed_in? %>
    <%= link_to "New product", new_product_path, class: "btn btn-success" %>
  <% else %>
    <%= link_to "Login", new_user_session_path, class: "btn btn-primary" %>
  <% end %>
</div>

<div class="row">
  <% @products.each do |product| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 product-card">
        <div class="card-body d-flex flex-column">

          <h5 class="card-title">
            <%= link_to product.name, product, class: "text-decoration-none" %>
                      <button class="btn btn-secondary mt-2 hide-btn">Hide</button>

          </h5>

          <!-- Hide Button -->

          <!-- This content will be hidden -->
          <div class="product-content mt-2">
            <div class="mt-auto">
              <%= button_to "Feature", feature_product_path(product),
                  method: :patch,
                  class: "btn btn-outline-primary btn-sm" %>
            </div>
          </div>

        </div>
      </div>
    </div>
  <% end %>
</div>

