<% if product.inventory_count.positive? %>
  <div class="alert alert-success">
    <strong><%= product.inventory_count %> in stock</strong>
  </div>
<% else %>
  <div class="alert alert-warning">
    <strong><%= product.name %> is out of stock</strong>
    <p>Add your email to be notified when available</p>

    <%= form_with model: [product, Subscriber.new], class: "mt-3" do |form| %>
      <div class="input-group">
        <%= form.email_field :email, placeholder: "johndoe@gmail.com", required: true, class: "form-control" %>
        <div class="input-group-append">
          <%= form.submit "Submit", class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>